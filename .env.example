# ============================================================
# TELEGRAM
# ============================================================
# Lấy từ @BotFather trên Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ============================================================
# GROQ AI (miễn phí, cực nhanh)
# ============================================================
# Lấy tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model Groq muốn dùng (tùy chọn, mặc định: llama-3.1-8b-instant)
# Các lựa chọn:
#   llama-3.1-8b-instant      → Siêu nhanh, phù hợp cho hầu hết
#   llama-3.3-70b-versatile   → Chất lượng cao nhất
#   gemma2-9b-it              → Google Gemma 2
#   mixtral-8x7b-32768        → Mixtral (context dài)
GROQ_MODEL=llama-3.1-8b-instant

# ============================================================
# WORDPRESS
# ============================================================
# URL website (không có / cuối)
WP_URL=https://yourwebsite.com

# Username đăng nhập WordPress
WP_USERNAME=admin

# Application Password (không phải password thường!)
# Tạo tại: WP Admin → Users → Profile → Application Passwords
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ============================================================
# BẢO MẬT (tùy chọn)
# ============================================================
# Danh sách Telegram User ID được phép dùng bot (ngăn cách bằng dấu phẩy)
# Để trống = cho phép tất cả mọi người
# Lấy User ID: nhắn tin cho @userinfobot trên Telegram
ALLOWED_USER_IDS=123456789,987654321
